      ],
      "id": "74b95590-3e67-45ca-910c-ff30ca02687c",
      "name": "webhook_whatsapp"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH existing_cliente AS (\n    SELECT *\n    FROM public.cliente\n    WHERE telefone = '{{ $json.telefone }}'\n    LIMIT 1\n), inserted_cliente AS (\n    INSERT INTO public.cliente (telefone)\n    SELECT '{{ $json.telefone }}'\n    WHERE NOT EXISTS (SELECT 1 FROM existing_cliente)\n    RETURNING *\n), final_cliente AS (\n    SELECT * FROM existing_cliente\n    UNION ALL\n    SELECT * FROM inserted_cliente\n), cliente_with_session AS (\n    SELECT \n        f.*,\n        s.session_id,\n        s.precisa_saudar,\n        us.transferido_para_humano,\n        us.id_agente_humano\n    FROM final_cliente f\n    CROSS JOIN LATERAL get_or_create_session(f.telefone) s\n    LEFT JOIN public.user_session us\n    ON us.id = s.session_id\n), agendamento_session AS (\n  SELECT sa.*\n    FROM public.sessao_agendamento sa\n    WHERE sa.telefone = '{{ $json.telefone }}'\n    ORDER BY sa.criado_em DESC  -- or sa.id DESC if that's your \"latest\"\n    LIMIT 1\n)\nSELECT json_build_object(\n    'cliente', to_jsonb(f) - 'session_id' - 'precisa_saudar' - 'transferido_para_humano' - 'id_agente_humano',\n    'session', json_build_object(\n        'session_id', f.session_id,\n        'precisa_saudar', f.precisa_saudar,\n        'transferido_para_humano', f.transferido_para_humano,\n        'id_agente_humano', f.id_agente_humano\n    ),'agendamento_session', json_build_object(\n        'unidade', sa.unidade,\n        'servico', sa.servico\n    )\n) AS result\nFROM cliente_with_session f\nLEFT JOIN agendamento_session sa ON sa.telefone = f.telefone;\n",
        "options": {}
      },
